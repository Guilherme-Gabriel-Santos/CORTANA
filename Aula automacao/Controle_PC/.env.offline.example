# Shared identity
OFFLINE_USER_ID=Guilherme
OFFLINE_FACE_AUTH_REQUIRED=0

# Local LLM via Ollama
OFFLINE_MODEL=llama3.2:3b
OFFLINE_TEMPERATURE=0.4

# Local speech-to-text
OFFLINE_STT_MODEL=small
OFFLINE_STT_DEVICE=auto
OFFLINE_STT_COMPUTE_TYPE=int8

# Microphone capture
OFFLINE_TEXT_ONLY=0
OFFLINE_INPUT_DEVICE=
OFFLINE_SAMPLE_RATE=16000
OFFLINE_SILENCE_THRESHOLD=0.006
OFFLINE_SILENCE_HOLD_SECONDS=1.2
OFFLINE_MAX_RECORD_SECONDS=10

# Local text-to-speech
OFFLINE_DISABLE_TTS=0
OFFLINE_TTS_RATE=190
OFFLINE_TTS_PROVIDER=edge
OFFLINE_EDGE_VOICE=pt-BR-ThalitaMultilingualNeural
OFFLINE_TTS_VOICE_NAME=HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Speech\Voices\Tokens\TTS_MS_PT-BR_MARIA_11.0
