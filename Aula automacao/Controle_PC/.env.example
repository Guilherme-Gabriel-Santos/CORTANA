# LiveKit worker
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Gemini / Google
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Assistant defaults
CORTANA_USER_ID=Guilherme
CORTANA_MODEL=gemini-2.5-flash-native-audio-latest

# Optional Face ID authentication
FACE_AUTH_REQUIRED=0
FACE_AUTH_PROFILE_NAME=Guilherme
FACE_AUTH_CAMERA_INDEX=0
FACE_AUTH_CONFIDENCE_THRESHOLD=60
FACE_AUTH_CONFIDENCE_MARGIN=12
FACE_AUTH_UNLOCK_STREAK=6
FACE_AUTH_SAMPLE_COUNT=25
FACE_AUTH_LOCK_GRACE_SECONDS=12
FACE_AUTH_PRESENCE_GRACE_SECONDS=45
FACE_AUTH_UNAUTHORIZED_GRACE_SECONDS=18
FACE_AUTH_FRAME_INTERVAL=0.20
FACE_AUTH_CONTINUOUS_MONITOR=0
FACE_AUTH_ADAPTIVE_LEARNING=1
FACE_AUTH_ADAPTIVE_SAMPLE_LIMIT=80
FACE_AUTH_ADAPTIVE_LEARNING_COOLDOWN_SECONDS=1800

# Optional Spotify integration
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional camera / sentry integration
YOOUSEE_IP=
YOOUSEE_USER=admin
YOOUSEE_PASSWORD=
YOOUSEE_RTSP_PORT=554
YOOUSEE_RTSP_PATH=/onvif1
CORTANA_ALERT_CONTACT=Guilherme
CORTANA_BRIDGE_SEND_URL=http://localhost:5050/send
# Open Interpreter Configuration
INTERPRETER_MODEL=ollama/llama3
